# ============================================================================
# secrets.env — Single source of truth for all credentials
# ============================================================================
#
# Usage:
#   1. Copy this file to `config/secrets.env` (which is gitignored).
#   2. Fill in every value below.
#   3. Run `bin/sync-secrets.sh` from the repo root to push them to
#      GitHub Actions Secrets in one shot.
#   4. Re-run `bin/sync-secrets.sh` whenever you rotate any key. The script is
#      idempotent — only changed values are updated.
#
# Security:
#   - This file MUST live only on your local machine. `.gitignore` excludes
#     `config/secrets.env` and `*.env` to prevent accidental commits.
#   - The recommended storage is your password manager's secure note feature
#     (1Password / Bitwarden / KeePassXC). Export to `config/secrets.env` only
#     when running the sync script, then delete the local copy.
#   - For team usage, store this file in a shared encrypted vault and gate
#     access with your IdP. Do NOT commit even an encrypted version to git
#     unless you set up SOPS or git-crypt with a key management plan.
#
# ============================================================================

# ----------------------------------------------------------------------------
# Runtime secrets (used by .github/workflows/main.yml — the news pipeline)
# ----------------------------------------------------------------------------

# Google AI Studio → API key → "Create API key in new project"
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI Platform → API keys → Create new secret key
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Cloudflare R2 — Manage R2 API tokens → Create API token (Object Read & Write)
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
CLOUDFLARE_R2_ACCOUNT=
CLOUDFLARE_R2_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Firebase Console → Project Settings → Service accounts → Generate new
# private key. Paste the entire JSON here as a single line (escape any
# embedded newlines in the private_key field as \n). The sync script handles
# the multi-line case automatically.
# https://console.firebase.google.com/
FIREBASE_SERVICE_ACCOUNT=

# Personal context for the filter prompt's {{user_context}} placeholder.
# Example: "I am a backend engineer in Tokyo interested in AI infrastructure
# and low-cost cloud operations. Score articles from this perspective."
AGENT_USER_CONTEXT=

# ----------------------------------------------------------------------------
# Deploy secrets (used by .github/workflows/deploy-cloudflare.yml)
# ----------------------------------------------------------------------------

# Cloudflare → My Profile → API Tokens → Create Token. Required scopes:
#   - Account · Workers Scripts · Edit
#   - Account · Cloudflare Pages · Edit
#   - Account · Workers R2 Storage · Edit
# This is DIFFERENT from CLOUDFLARE_R2_KEY/SECRET above. R2 keys are
# S3-compatible data plane credentials (can put objects); this token is
# the management plane bearer token (can deploy Worker / Pages / create
# buckets). Both are required.
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID — visible in the right sidebar of the dashboard,
# or via `wrangler whoami` after authenticating once.
CLOUDFLARE_ACCOUNT_ID=
